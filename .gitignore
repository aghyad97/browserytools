# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


docs/*
!docs/superpowers/
plans/
!docs/superpowers/plans/
# ffmpeg.wasm core — generated by scripts/copy-ffmpeg.mjs at install/build
/public/ffmpeg/

# tesseract.js core/worker — generated by scripts/copy-tesseract.js
/public/tesseract/
